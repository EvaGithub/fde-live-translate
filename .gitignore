# secrets & env — never commit these
.env
*.env
!.env.example

# python
.venv/
__pycache__/
*.pyc

# node
node_modules/

# cache data & logs (regenerated at runtime)
*.db
*.log
*.out

# intermediate benchmark output (regenerated by eval/bench)
_bench.json

# video recordings (submit separately / host externally — don't bloat the repo)
*.mov
*.mp4
*.m4v
